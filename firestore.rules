rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /outfits/{outfitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Style Profiles: owner can write, authenticated users can read (for matching)
    match /styleProfiles/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Matches: participants can read, system (functions) writes
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Master data: anyone authenticated can read
    match /archetypes/{docId} {
      allow read: if request.auth != null;
    }
    match /dateMoods/{docId} {
      allow read: if request.auth != null;
    }
  }
}
